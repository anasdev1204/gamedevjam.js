code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_disabled, diffuse_lambert, specular_schlick_ggx;


// Varyings
varying float var_shade;

uniform sampler2D albedo;



void fragment() {
	vec4 n_out2p0;
// Texture2D:2
	n_out2p0 = texture(albedo, UV);


// Output:0
	ALBEDO = vec3(n_out2p0.xyz);


// Input:4
	vec4 n_out4p0 = COLOR;


// VectorDecompose:5
	float n_out5p0 = vec3(n_out4p0.xyz).x;
	float n_out5p1 = vec3(n_out4p0.xyz).y;
	float n_out5p2 = vec3(n_out4p0.xyz).z;


	var_shade = 0.0;
}

void light() {
// VaryingGetter:12
	float n_out12p0 = var_shade;


// Input:2
	vec3 n_out2p0 = NORMAL;


// Input:3
	vec3 n_out3p0 = LIGHT;


// DotProduct:4
	float n_out4p0 = dot(n_out2p0, n_out3p0);


// FloatOp:13
	float n_out13p0 = n_out12p0 * n_out4p0;


// SmoothStep:5
	float n_in5p0 = 0.10000;
	float n_in5p1 = 0.10000;
	float n_out5p0 = smoothstep(n_in5p0, n_in5p1, n_out13p0);


// SmoothStep:7
	float n_in7p0 = 0.10000;
	float n_in7p1 = 0.25000;
	float n_out7p0 = smoothstep(n_in7p0, n_in7p1, n_out13p0);


// Mix:8
	float n_in8p2 = 0.50000;
	float n_out8p0 = mix(n_out5p0, n_out7p0, n_in8p2);


// ColorConstant:10
	vec4 n_out10p0 = vec4(1.000000, 1.000000, 1.000000, 1.000000);


// Fresnel:6
	float n_in6p3 = 1.00000;
	float n_out6p0 = pow(1.0 - clamp(dot(NORMAL, VIEW), 0.0, 1.0), n_in6p3);


// SmoothStep:9
	float n_in9p0 = 0.25000;
	float n_in9p1 = 0.25000;
	float n_out9p0 = smoothstep(n_in9p0, n_in9p1, n_out6p0);


// Mix:11
	float n_out11p0 = mix(n_out8p0, n_out10p0.x, n_out9p0);


// Output:0
	DIFFUSE_LIGHT = vec3(n_out11p0);


}
"
